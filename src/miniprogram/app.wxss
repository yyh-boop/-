/* 全局样式 - 深蓝科技风底色 */
page {
  min-height: 100%;
  background: radial-gradient(circle at top, #12335f 0%, #0a1a38 45%, #060c1a 100%);
  color: #e8f3ff;
  font-family: -apple-system, "PingFang SC", "Helvetica Neue", sans-serif;
}

.container {
  padding: 36rpx 28rpx 60rpx;
  box-sizing: border-box;
}
